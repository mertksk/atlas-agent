# ───────────────────────────── Casper Testnet (contracts/livenet CLI) ─────
# Used by: cargo run --bin atlas_livenet --features livenet -- <command>
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.casper.network/rpc
ODRA_CASPER_LIVENET_EVENTS_URL=https://node.testnet.casper.network/events
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test
# Two-key model (recommended): the AGENT key signs the agent's own calls; the
# OWNER key signs human approvals (allocations >= the approval threshold).
# Single-key dev: set only the first and leave OWNER_SECRET_KEY_PATH unset.
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=/path/to/agent_secret_key.pem
# OWNER_SECRET_KEY_PATH=/path/to/owner_secret_key.pem

# ───────────────────────────── Data services (services/) ─────────────────
SERVICES_PORT=4021
X402_NETWORK=casper:casper-test
X402_PAY_TO=atlas-data-services-demo-payee
X402_ASSET=CSPR
# --- Real on-chain x402 settlement (CEP-18 via the Casper x402 facilitator) ---
# Run `bash scripts/setup-facilitator.sh` first, then uncomment these. Leave the
# whole block commented for zero-setup mock mode.
# FACILITATOR_URL=http://localhost:4022
# X402_ASSET_PACKAGE=<64-hex CEP-18 (transfer_with_authorization) package hash>
# X402_PAYEE=00<64-hex account hash>            # data-services payee
# X402_TOKEN_NAME="Casper X402 Token"           # must match the token's EIP-712 domain name
# X402_TOKEN_VERSION=1
# X402_TOKEN_DECIMALS=9
# X402_PAYER_KEY_PATH=/path/to/payer_secret_key.pem   # agent-side payer (holds the CEP-18 token)
# X402_PAYER_KEY_ALGO=ed25519
# Recipient addresses for the five demo strategies (defaults are placeholders)
# STRATEGY_ADDR_1=account-hash-...
# STRATEGY_ADDR_2=account-hash-...
# STRATEGY_ADDR_3=account-hash-...
# STRATEGY_ADDR_4=account-hash-...
# STRATEGY_ADDR_5=account-hash-...

# ───────────────────────────── Agent (agent/) ────────────────────────────
AGENT_PORT=4030
SERVICES_URL=http://localhost:4021
# Bearer token for POST /api/run and /api/approve. Strongly recommended for any
# non-localhost deployment (without it those endpoints are unauthenticated).
# AGENT_API_TOKEN=change-me-to-a-long-random-string
# Optional: Claude as the Treasurer (falls back to the deterministic scorer)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5
# Optional: an OpenRouter-hosted Treasurer (e.g. Gemma 4). Takes precedence over
# Claude. Cascade on error: openrouter -> claude -> deterministic.
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=google/gemma-4-26b-a4b-it
# Chain writes: keep true until contracts are deployed and a key is funded
DRY_RUN=true
# VAULT_ADDRESS=hash-...
# REGISTRY_ADDRESS=hash-...
# How the agent invokes the livenet CLI (override if you prebuilt the binary)
# LIVENET_CMD=cargo run --quiet --bin atlas_livenet --features livenet --manifest-path ../contracts/Cargo.toml --
# Simulated balance while DRY_RUN (live mode reads the vault)
TREASURY_BALANCE_CSPR=100

# Treasury policy (mirrored by the on-chain vault policy)
POLICY_MAX_PER_OP=30
POLICY_MAX_DAILY=50
POLICY_MIN_CONFIDENCE=0.7
POLICY_MAX_RISK=60
POLICY_APPROVAL_THRESHOLD=25
POLICY_DATA_BUDGET=4

# ───────────────────────────── Dashboard (web/) ──────────────────────────
NEXT_PUBLIC_AGENT_URL=http://localhost:4030

# ───────────────────────────── MCP server (agent/src/mcp.ts) ─────────────
AGENT_URL=http://localhost:4030

# DATA_SOURCE=defillama   # live DeFi yields from yields.llama.fi (free, no key); default = mock marketplace

# NEXT_PUBLIC_AGENT_API_TOKEN=   # local-only: auto-fills the dashboard token field. Never set on a public deploy (bakes the token into the client bundle).

# --- cspr.trade real DEX execution (optional) ---
# When true, a live ALLOCATE performs a REAL on-chain CSPR->WUSDC swap on the
# cspr.trade Uniswap-V2 DEX (agent key signs; WUSDC lands in CSPRTRADE_RECIPIENT)
# instead of the vault placeholder transfer. Default off. Uses agent operational
# CSPR + gas. Addresses default to the verified testnet package hashes.
# CSPRTRADE_ENABLED=false
# CSPRTRADE_SLIPPAGE_BPS=200        # 2%
# CSPRTRADE_MAX_SWAP_CSPR=25        # per-swap safety cap
# CSPRTRADE_ROUTER=hash-04a11a367e708c52557930c4e9c1301f4465100d1b1b6d0a62b48d3e32402867
# CSPRTRADE_WCSPR=hash-3d80df21ba4ee4d66a2a1f60c32570dd5685e4b279f6538162a5fd1314847c1e
# CSPRTRADE_WUSDC=hash-073024d1112dd970cc75b797952a70f71efe3a8a69af152e8fbe8ef434823396
# CSPRTRADE_POOL=8747a781dab337b8014a66865355648223c05439684e62f90c1dbe18e4ed7c3a
# CSPRTRADE_RECIPIENT=account-hash-...   # where swapped WUSDC lands (agent-controlled)
